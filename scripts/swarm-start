#!/bin/bash
# swarm-start — Launch an agent swarm on an existing project.
#
# Architecture:
#   Pane 0: PA (Personal Assistant) — your interactive agent
#   Pane 1: Lead agent — autonomous, loops forever polling Agent Mail
#   Panes 2+: Worker agents — each in its own git worktree
#
# Prerequisites:
#   - tmux (brew install tmux)
#   - claude (Claude Code CLI)
#   - br (beads_rust)
#   - bv (beads_viewer)
#   - Agent Mail MCP server running on port 8765
#
# Usage:
#   swarm-start <project-dir> [--workers N] [--model MODEL]

set -euo pipefail

WORKERS=2
WORKER_MODEL=""
AGENT_MAIL_PORT=8765
AGENT_MAIL_HEALTH="http://127.0.0.1:${AGENT_MAIL_PORT}/api/health"

usage() {
    echo "Usage: swarm-start <project-dir> [--workers N] [--model MODEL]"
    echo ""
    echo "Launches a PA + lead agent + N worker agents in tmux panes."
    echo ""
    echo "Options:"
    echo "  --workers N     Number of worker agents (default: 2)"
    echo "  --model MODEL   Model for worker agents (default: same as lead)"
    echo "  --help          Show this help"
    exit 1
}

if [ $# -lt 1 ]; then
    usage
fi

PROJECT_DIR="$(cd "$1" && pwd)"
shift

while [ $# -gt 0 ]; do
    case "$1" in
        --workers)
            WORKERS="$2"
            shift 2
            ;;
        --model)
            WORKER_MODEL="$2"
            shift 2
            ;;
        --help)
            usage
            ;;
        *)
            echo "Unknown option: $1"
            usage
            ;;
    esac
done

PROJECT_NAME="$(basename "$PROJECT_DIR")"

# --- Preflight checks ---

echo "Preflight checks..."

if ! command -v tmux &>/dev/null; then
    echo "ERROR: tmux is required. Install with: brew install tmux"
    exit 1
fi

if ! command -v claude &>/dev/null; then
    echo "ERROR: claude (Claude Code CLI) not found"
    exit 1
fi

if ! command -v br &>/dev/null; then
    echo "ERROR: br (beads_rust) not found. Install: curl -fsSL https://raw.githubusercontent.com/Dicklesworthstone/beads_rust/main/install.sh | bash"
    exit 1
fi

if ! command -v bv &>/dev/null; then
    echo "WARNING: bv (beads_viewer) not found. Lead agent will not have graph-based triage."
fi

if [ ! -d "$PROJECT_DIR/.git" ]; then
    echo "ERROR: $PROJECT_DIR is not a git repository"
    exit 1
fi

if [ ! -d "$PROJECT_DIR/.beads" ]; then
    echo "Initializing beads workspace..."
    (cd "$PROJECT_DIR" && br init)
fi

# --- Agent Mail ---

echo "Checking Agent Mail MCP server..."

if curl -sf "$AGENT_MAIL_HEALTH" > /dev/null 2>&1; then
    echo "  Agent Mail is running on port $AGENT_MAIL_PORT"
else
    echo "  Agent Mail is not running. Starting it..."

    AGENT_MAIL_DIR="$HOME/code/mcp_agent_mail"
    if [ ! -d "$AGENT_MAIL_DIR" ]; then
        for dir in "$HOME/code/mcp-agent-mail" "$HOME/projects/mcp_agent_mail"; do
            if [ -d "$dir" ]; then
                AGENT_MAIL_DIR="$dir"
                break
            fi
        done
    fi

    if [ ! -d "$AGENT_MAIL_DIR" ]; then
        echo "ERROR: Cannot find Agent Mail source repo."
        echo "Expected at: $HOME/code/mcp_agent_mail"
        echo "Start it manually: cd <agent-mail-dir> && uv run python -m mcp_agent_mail.cli serve-http"
        exit 1
    fi

    echo "  Starting from $AGENT_MAIL_DIR ..."
    (cd "$AGENT_MAIL_DIR" && nohup uv run python -m mcp_agent_mail.cli serve-http > /tmp/agent-mail.log 2>&1 &)

    for i in $(seq 1 10); do
        if curl -sf "$AGENT_MAIL_HEALTH" > /dev/null 2>&1; then
            echo "  Agent Mail started (PID: $(lsof -ti :$AGENT_MAIL_PORT | head -1))"
            break
        fi
        if [ "$i" -eq 10 ]; then
            echo "ERROR: Agent Mail failed to start. Check /tmp/agent-mail.log"
            exit 1
        fi
        sleep 1
    done
fi

# --- Uncommitted changes warning ---

if git -C "$PROJECT_DIR" status --porcelain CLAUDE.md AGENTS.md .claude/settings.json 2>/dev/null | grep -q .; then
    echo ""
    echo "WARNING: Uncommitted changes to CLAUDE.md, AGENTS.md, or settings.json."
    echo "Worktree agents will NOT see these changes. Commit first?"
    echo ""
    read -p "Continue anyway? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# --- Build tmux session ---

SESSION="swarm-${PROJECT_NAME}"

tmux kill-session -t "$SESSION" 2>/dev/null || true

echo ""
echo "Launching swarm: 1 PA + 1 lead + $WORKERS workers"
echo "tmux session: $SESSION"
echo ""

MODEL_FLAG=""
if [ -n "$WORKER_MODEL" ]; then
    MODEL_FLAG="--model $WORKER_MODEL"
fi

# --- Write prompt files ---

PROMPT_DIR="/tmp/swarm-${PROJECT_NAME}"
mkdir -p "$PROMPT_DIR"

# Create a shared roster file for agent discovery
ROSTER_FILE="$PROMPT_DIR/roster.txt"
echo "# Swarm roster: ROLE=AgentMailName" > "$ROSTER_FILE"

# Create signal directory
mkdir -p "$PROMPT_DIR/signals"

# === PA (Personal Assistant) system prompt ===
cat > "$PROMPT_DIR/pa-system.txt" <<PAEOF
You are the Personal Assistant (PA) for the $PROJECT_NAME swarm.
You are the user's interface to the swarm.

YOUR ROLE:
- Take instructions from the user and relay them to the lead agent via send_message
- Check fetch_inbox to show the user status updates from lead/workers
- Help the user review PRs, check bv triage, inspect beads status

AGENT DISCOVERY:
Read $PROMPT_DIR/roster.txt for Agent Mail names of all agents.

ON STARTUP:
1. Call macro_start_session to register with Agent Mail
2. Write your name to roster: echo "PA=YourName" >> $PROMPT_DIR/roster.txt
3. Read the roster and tell the user the swarm status
PAEOF

# === Lead agent system prompt ===
cat > "$PROMPT_DIR/lead-system.txt" <<LEADEOF
You are the lead agent for the $PROJECT_NAME project.
Your ONLY job is to plan, delegate, and coordinate. You are a MANAGER, not a coder.
You are invoked repeatedly via "claude -p" every 90 seconds — each invocation is a fresh context.
Do everything you need to do in THIS invocation, then exit cleanly.
Do NOT say you will wait or poll later — you will be automatically re-invoked in 90 seconds.
Do NOT sleep or set timers. Just do your work and finish.

YOU MUST NOT:
- Write code yourself
- Use the Edit, Write, or Agent tool to implement features
- Spawn sub-agents to do coding work
- Claim tasks with br update --status=in_progress (that's for workers)

YOU MUST:
- Create and organize beads (tasks) with br create
- Assign tasks to worker agents via Agent Mail send_message
- Monitor worker progress via fetch_inbox
- Review PRs and merge completed worker branches into main
- Re-triage and assign new work when tasks complete

YOU HAVE $WORKERS WORKER AGENTS:
$(for j in $(seq 1 $WORKERS); do echo "- worker-$j (in their own git worktree)"; done)

AGENT DISCOVERY:
Read $PROMPT_DIR/roster.txt for Agent Mail names. Format: ROLE=AgentMailName.
Use the Agent Mail name from the roster when sending messages, NOT "worker-1".

EACH INVOCATION, DO THIS:
1. Call macro_start_session to register with Agent Mail
2. Write your name to roster: echo "lead=YourName" >> $PROMPT_DIR/roster.txt
3. Read $PROMPT_DIR/roster.txt for worker names
4. Check fetch_inbox for messages from workers and the PA
5. If a worker submitted a PR: review it (gh pr diff), approve or request changes
6. If a PR is approved: gh pr merge, git pull, br sync --rebuild, assign next task
7. If workers are idle (no in-progress tasks): run bv --robot-triage, assign ready beads
8. If no beads exist: read PROJECT.md, create initial beads with br create
9. Run br sync --flush-only before finishing

REVIEW WORKFLOW:
1. gh pr diff <N> — read the diff
2. Check: matches bead? has tests? bugs? style?
3. Issues: gh pr review <N> --request-changes --body "feedback" + Agent Mail to worker
4. Good: gh pr review <N> --approve + gh pr merge <N> --merge

RATE LIMITING:
- Only check GitHub when a worker says a PR is ready via Agent Mail
- If you get a 429, stop and try next invocation

HANDLING br ERRORS:
- "FOREIGN KEY constraint failed": run br sync --rebuild, retry once, skip if still fails
- Already-closed beads: just move on
LEADEOF

# === Lead agent loop script ===
cat > "$PROMPT_DIR/lead-loop.sh" <<'LOOPEOF'
#!/bin/bash
PROJECT_DIR="$1"
PROMPT_DIR="$2"
cd "$PROJECT_DIR"

echo "[lead-loop] Starting lead agent loop"

# First run: full startup
claude -p "First run. Read PROJECT.md and AGENTS.md. Register with Agent Mail. Create beads if none exist. Read the roster, assign tasks to workers. Do everything in your system prompt." \
    --append-system-prompt-file "$PROMPT_DIR/lead-system.txt"

# Poll loop: runs forever
while true; do
    sleep 90
    echo "[lead-loop] Polling..."
    claude -p "Poll: check inbox, review PRs, merge approved, assign idle workers." \
        --append-system-prompt-file "$PROMPT_DIR/lead-system.txt"
done
LOOPEOF
chmod +x "$PROMPT_DIR/lead-loop.sh"

# === Worker loop scripts ===
for i in $(seq 1 "$WORKERS"); do
    WORKER_NAME="worker-$i"
    WORKTREE_DIR="$PROJECT_DIR/.claude/worktrees/$WORKER_NAME"

    cat > "$PROMPT_DIR/${WORKER_NAME}-system.txt" <<WORKEREOF
You are worker agent $WORKER_NAME for the $PROJECT_NAME project.
You are a CODER. You implement tasks assigned by the lead agent.
You are invoked repeatedly via "claude -p" every 90 seconds — each invocation is a fresh context.
Complete your task fully in THIS invocation, then exit cleanly.
Do NOT say you will wait or poll later — you will be automatically re-invoked in 90 seconds.
Do NOT sleep or set timers. Just do your work and finish.

AGENT DISCOVERY:
Read $PROMPT_DIR/roster.txt for Agent Mail names of all agents.

EACH INVOCATION, DO THIS:
1. Call macro_start_session to register with Agent Mail
2. Write your name to roster: echo "$WORKER_NAME=YourName" >> $PROMPT_DIR/roster.txt
3. Check fetch_inbox for task assignments from the lead agent
4. If no task, check br ready for available work
5. If still no task, exit — you will be invoked again in 90 seconds

WORK PROTOCOL — when you have a task:
1. git pull origin main --rebase
2. br sync --rebuild
3. br update <id> --status=in_progress (skip if FK error)
4. Reserve files: file_reservation_paths with exclusive=true
5. Create feature branch: git checkout -b feature/<bead-id>-<short-desc>
6. Implement the task fully
7. Write tests
8. Run tests — make sure they pass
9. Release file reservations
10. br close <id> (skip if FK error)
11. br sync --flush-only
12. git add, commit, push: git push -u origin feature/<bead-id>-<short-desc>
13. Create PR: gh pr create --title "<bead-id>: desc" --body "what you built"
14. Send Agent Mail to lead with PR number and bead ID
15. Touch signal: touch $PROMPT_DIR/signals/$WORKER_NAME-done

IF LEAD REQUESTS PR CHANGES:
1. Read feedback from fetch_inbox
2. Fix issues on your feature branch
3. Commit, push
4. Reply via Agent Mail

IMPORTANT:
- You are in a git worktree — do NOT merge to main
- Always reserve files before editing, release when done
- If br fails with FK error: br sync --rebuild, retry once, skip if still fails
WORKEREOF

    cat > "$PROMPT_DIR/${WORKER_NAME}-loop.sh" <<WLOOPEOF
#!/bin/bash
WORKER_NAME="$WORKER_NAME"
WORKTREE_DIR="$WORKTREE_DIR"
PROMPT_DIR="$PROMPT_DIR"

echo "[\$WORKER_NAME] Starting worker loop"

# Wait for worktree to exist
while [ ! -d "\$WORKTREE_DIR" ]; do
    sleep 5
done
cd "\$WORKTREE_DIR"

# First run: register and check for work
claude -p "First run. Register with Agent Mail, check inbox for tasks, check br ready. If you have a task, do the full WORK PROTOCOL." \\
    --append-system-prompt-file "\$PROMPT_DIR/\${WORKER_NAME}-system.txt"

# Poll loop
while true; do
    if [ -f "\$PROMPT_DIR/signals/\${WORKER_NAME}-done" ]; then
        rm -f "\$PROMPT_DIR/signals/\${WORKER_NAME}-done"
        echo "[\$WORKER_NAME] Task complete. Fresh context for next task."
    fi

    sleep 90
    cd "\$WORKTREE_DIR"
    echo "[\$WORKER_NAME] Polling..."
    claude -p "Poll: check fetch_inbox for tasks. If assigned, do full WORK PROTOCOL." \\
        --append-system-prompt-file "\$PROMPT_DIR/\${WORKER_NAME}-system.txt"
done
WLOOPEOF
    chmod +x "$PROMPT_DIR/${WORKER_NAME}-loop.sh"
done

# --- Create initial worktrees for workers ---
for i in $(seq 1 "$WORKERS"); do
    WORKER_NAME="worker-$i"
    WORKTREE_DIR="$PROJECT_DIR/.claude/worktrees/$WORKER_NAME"
    if [ ! -d "$WORKTREE_DIR" ]; then
        echo "  Creating worktree for $WORKER_NAME..."
        git -C "$PROJECT_DIR" worktree add "$WORKTREE_DIR" -b "worktree-$WORKER_NAME" 2>/dev/null || true
    fi
done

# --- Launch tmux session ---

# Pane 0: PA (interactive — this is where the user lives)
tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR"
sleep 1
tmux send-keys -t "$SESSION" "cd '$PROJECT_DIR' && claude --append-system-prompt-file '$PROMPT_DIR/pa-system.txt'" Enter

# Pane 1: Lead agent (autonomous -p loop)
tmux split-window -t "$SESSION" -c "$PROJECT_DIR"
sleep 1
tmux send-keys -t "$SESSION" "bash '$PROMPT_DIR/lead-loop.sh' '$PROJECT_DIR' '$PROMPT_DIR'" Enter

# Panes 2+: Workers (autonomous -p loops, staggered)
for i in $(seq 1 "$WORKERS"); do
    WORKER_NAME="worker-$i"
    tmux split-window -t "$SESSION" -c "$PROJECT_DIR"
    sleep 1
    tmux send-keys -t "$SESSION" "sleep ${i}0 && bash '$PROMPT_DIR/${WORKER_NAME}-loop.sh' '$PROJECT_DIR' '$PROMPT_DIR'" Enter
done

# Layout all panes
tmux select-layout -t "$SESSION" tiled

echo ""
echo "Swarm launched in tmux session: $SESSION"
echo ""
echo "Panes:"
echo "  0 = PA (interactive — talk to this one)"
echo "  1 = Lead (autonomous -p loop, polls every 90s)"
for i in $(seq 1 "$WORKERS"); do
    echo "  $(( i + 1 )) = worker-$i (autonomous -p loop)"
done
echo ""
echo "Commands:"
echo "  tmux attach -t $SESSION            # View the swarm"
echo "  tmux kill-session -t $SESSION      # Stop the swarm"
echo ""
echo "Cleanup when done:"
echo "  scripts/swarm-kill $PROJECT_DIR"
