#!/bin/bash
# swarm-start — Launch an agent swarm on an existing project.
#
# Starts a lead agent + N worker agents, each in its own git worktree
# and tmux pane. The lead agent triages work with bv and coordinates
# workers via Agent Mail.
#
# Prerequisites:
#   - tmux (brew install tmux)
#   - claude (Claude Code CLI)
#   - br (beads_rust)
#   - bv (beads_viewer)
#   - Agent Mail MCP server running on port 8765
#
# Usage:
#   swarm-start <project-dir> [--workers N] [--model MODEL]
#
# Examples:
#   swarm-start ~/code/my-app                  # 1 lead + 2 workers
#   swarm-start ~/code/my-app --workers 4      # 1 lead + 4 workers
#   swarm-start ~/code/my-app --model sonnet   # Use sonnet for workers

set -euo pipefail

WORKERS=2
WORKER_MODEL=""
AGENT_MAIL_PORT=8765
AGENT_MAIL_HEALTH="http://127.0.0.1:${AGENT_MAIL_PORT}/api/health"

usage() {
    echo "Usage: swarm-start <project-dir> [--workers N] [--model MODEL]"
    echo ""
    echo "Launches a lead agent + N worker agents in tmux panes."
    echo ""
    echo "Options:"
    echo "  --workers N     Number of worker agents (default: 2)"
    echo "  --model MODEL   Model for worker agents (default: same as lead)"
    echo "  --help          Show this help"
    exit 1
}

if [ $# -lt 1 ]; then
    usage
fi

PROJECT_DIR="$(cd "$1" && pwd)"
shift

while [ $# -gt 0 ]; do
    case "$1" in
        --workers)
            WORKERS="$2"
            shift 2
            ;;
        --model)
            WORKER_MODEL="$2"
            shift 2
            ;;
        --help)
            usage
            ;;
        *)
            echo "Unknown option: $1"
            usage
            ;;
    esac
done

PROJECT_NAME="$(basename "$PROJECT_DIR")"

# --- Preflight checks ---

echo "Preflight checks..."

# tmux
if ! command -v tmux &>/dev/null; then
    echo "ERROR: tmux is required. Install with: brew install tmux"
    exit 1
fi

# claude
if ! command -v claude &>/dev/null; then
    echo "ERROR: claude (Claude Code CLI) not found"
    exit 1
fi

# br
if ! command -v br &>/dev/null; then
    echo "ERROR: br (beads_rust) not found. Install: curl -fsSL https://raw.githubusercontent.com/Dicklesworthstone/beads_rust/main/install.sh | bash"
    exit 1
fi

# bv
if ! command -v bv &>/dev/null; then
    echo "WARNING: bv (beads_viewer) not found. Lead agent will not have graph-based triage."
fi

# Project dir
if [ ! -d "$PROJECT_DIR/.git" ]; then
    echo "ERROR: $PROJECT_DIR is not a git repository"
    exit 1
fi

# Beads workspace
if [ ! -d "$PROJECT_DIR/.beads" ]; then
    echo "Initializing beads workspace..."
    (cd "$PROJECT_DIR" && br init)
fi

# --- Agent Mail ---

echo "Checking Agent Mail MCP server..."

if curl -sf "$AGENT_MAIL_HEALTH" > /dev/null 2>&1; then
    echo "  Agent Mail is running on port $AGENT_MAIL_PORT"
else
    echo "  Agent Mail is not running. Starting it..."

    # Look for the Agent Mail source repo
    AGENT_MAIL_DIR="$HOME/code/mcp_agent_mail"
    if [ ! -d "$AGENT_MAIL_DIR" ]; then
        # Try common alternative locations
        for dir in "$HOME/code/mcp-agent-mail" "$HOME/projects/mcp_agent_mail"; do
            if [ -d "$dir" ]; then
                AGENT_MAIL_DIR="$dir"
                break
            fi
        done
    fi

    if [ ! -d "$AGENT_MAIL_DIR" ]; then
        echo "ERROR: Cannot find Agent Mail source repo."
        echo "Expected at: $HOME/code/mcp_agent_mail"
        echo "Start it manually: cd <agent-mail-dir> && uv run python -m mcp_agent_mail.cli serve-http"
        exit 1
    fi

    echo "  Starting from $AGENT_MAIL_DIR ..."
    (cd "$AGENT_MAIL_DIR" && nohup uv run python -m mcp_agent_mail.cli serve-http > /tmp/agent-mail.log 2>&1 &)

    # Wait for it to come up
    for i in $(seq 1 10); do
        if curl -sf "$AGENT_MAIL_HEALTH" > /dev/null 2>&1; then
            echo "  Agent Mail started (PID: $(lsof -ti :$AGENT_MAIL_PORT | head -1))"
            break
        fi
        if [ "$i" -eq 10 ]; then
            echo "ERROR: Agent Mail failed to start. Check /tmp/agent-mail.log"
            exit 1
        fi
        sleep 1
    done
fi

# --- Uncommitted changes warning ---

if git -C "$PROJECT_DIR" status --porcelain CLAUDE.md AGENTS.md .claude/settings.json 2>/dev/null | grep -q .; then
    echo ""
    echo "WARNING: Uncommitted changes to CLAUDE.md, AGENTS.md, or settings.json."
    echo "Worktree agents will NOT see these changes. Commit first?"
    echo ""
    read -p "Continue anyway? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# --- Build tmux session ---

SESSION="swarm-${PROJECT_NAME}"

# Kill existing session if present
tmux kill-session -t "$SESSION" 2>/dev/null || true

echo ""
echo "Launching swarm: 1 lead + $WORKERS workers"
echo "tmux session: $SESSION"
echo ""

# Build model flag for workers
MODEL_FLAG=""
if [ -n "$WORKER_MODEL" ]; then
    MODEL_FLAG="--model $WORKER_MODEL"
fi

# Read the lead agent prompt
LEAD_PROMPT="You are the lead agent for the $PROJECT_NAME project.

Your job is to plan and coordinate work across $WORKERS worker agents.

STARTUP PROTOCOL:
1. Read PROJECT.md to understand the project
2. Read AGENTS.md for coordination rules
3. Call macro_start_session to register with Agent Mail
4. Run install_precommit_guard to set up the file reservation git hook
5. Run br ready to see existing work
6. Run bv --robot-triage to get ranked recommendations (if beads exist)
7. If no beads exist yet, analyze PROJECT.md and create initial beads with br create

ONGOING PROTOCOL:
- Use bv --robot-plan to identify parallel execution tracks
- Assign tasks to workers via Agent Mail send_message
- Include: bead ID, expected files to touch, any context or dependencies
- Monitor progress via fetch_inbox and bv --robot-alerts
- When workers complete tasks, review and merge their branches
- Re-triage after each completion cycle with bv --robot-triage
- Create new beads as you discover additional work

IMPORTANT:
- Workers are in separate worktrees on their own branches
- Coordinate merges — do not let workers merge to main themselves
- Use bv --robot-insights | jq '.Cycles' if you suspect dependency cycles
- Sync beads before and after coordination: br sync --flush-only"

# Create the tmux session with the lead agent in the first pane
tmux new-session -d -s "$SESSION" -c "$PROJECT_DIR"
tmux send-keys -t "$SESSION" "cd '$PROJECT_DIR' && claude --dangerously-skip-permissions -p '$(echo "$LEAD_PROMPT" | sed "s/'/'\\\\''/g")'" Enter

# Stagger worker starts to avoid thundering herd
for i in $(seq 1 "$WORKERS"); do
    WORKER_NAME="worker-$i"

    # Build the worker prompt
    WORKER_PROMPT="You are worker agent $WORKER_NAME for the $PROJECT_NAME project.

STARTUP PROTOCOL:
1. Read AGENTS.md for coordination rules
2. Call macro_start_session to register with Agent Mail
3. Check fetch_inbox for task assignments from the lead agent
4. Run br ready to see available work

WORK PROTOCOL:
- When you receive a task assignment via Agent Mail, claim it: br update <id> --status=in_progress
- Reserve files before editing: file_reservation_paths with exclusive=true
- Work on the task in your worktree branch
- Run tests before committing
- When done: release reservations, br close <id>, br sync --flush-only, commit, push
- Send completion message via Agent Mail
- Check fetch_inbox and br ready for next task

IMPORTANT:
- You are in a git worktree — your branch is $WORKER_NAME
- Do NOT merge to main — the lead agent handles merges
- Always reserve files before editing and release when done
- Communicate blockers immediately via Agent Mail"

    echo "  Starting $WORKER_NAME (staggered ${i}0s delay)..."

    # Create a new tmux pane for this worker
    tmux split-window -t "$SESSION" -c "$PROJECT_DIR"
    tmux send-keys -t "$SESSION" "sleep ${i}0 && cd '$PROJECT_DIR' && claude --worktree '$WORKER_NAME' --dangerously-skip-permissions $MODEL_FLAG -p '$(echo "$WORKER_PROMPT" | sed "s/'/'\\\\''/g")'" Enter

    # Re-layout panes evenly after each addition
    tmux select-layout -t "$SESSION" tiled
done

echo ""
echo "Swarm launched in tmux session: $SESSION"
echo ""
echo "Commands:"
echo "  tmux attach -t $SESSION          # View the swarm"
echo "  tmux select-pane -t $SESSION:0.N # Focus pane N (0=lead, 1+=workers)"
echo "  tmux kill-session -t $SESSION    # Stop the swarm"
echo ""
echo "Worktrees:"
git -C "$PROJECT_DIR" worktree list 2>/dev/null || echo "  (workers will create worktrees on start)"
echo ""
echo "Cleanup when done:"
echo "  scripts/swarm-stop $PROJECT_DIR"
